---
import BaseLayout from '../layouts/BaseLayout.astro';

const query = Astro.url.searchParams.get('q') || '';
---

<BaseLayout title={`Search${query ? ` - ${query}` : ''} | George Ollis`} description="Search blog posts and guides.">
  <section class="section-block search-results">
    <p class="section-label">Search</p>
    <h1>Search Results</h1>

    <div id="pagefind-ui"></div>
  </section>
</BaseLayout>

<style>
  .search-results {
    max-width: 900px;
  }

  :global(.pagefind-ui) {
    --pagefind-ui-primary: #3a4146;
    --pagefind-ui-text: #2f3437;
    --pagefind-ui-background: #F5F2EB;
    --pagefind-ui-border: #D4C9B9;
    --pagefind-ui-shadow: rgba(58, 65, 70, 0.1);
  }

  :global(.pagefind-ui__search-input) {
    border-radius: 0.5rem;
    padding: 0.75rem 1rem;
  }

  :global(.pagefind-ui__results-container) {
    margin-top: 1.5rem;
  }

  :global(.pagefind-ui__result) {
    border: 1px solid #D4C9B9;
    border-radius: 0.5rem;
    padding: 1.25rem;
    margin-bottom: 1rem;
  }

  :global(.pagefind-ui__result:hover) {
    border-color: #3a4146;
    box-shadow: 0 4px 12px rgba(58, 65, 70, 0.08);
  }
</style>

<script define:vars={{ query }}>
  if (window.PagefindUI) {
    const pagefind = new window.PagefindUI({
      element: '#pagefind-ui',
      showSubResults: true,
      autofocus: true
    });
    
    if (query) {
      // Pre-fill search with query term
      const searchInput = document.querySelector('.pagefind-ui__search-input');
      if (searchInput) {
        searchInput.value = query;
        // Trigger search
        searchInput.dispatchEvent(new Event('input', { bubbles: true }));
      }
    }
  }
</script>
