---
import BaseLayout from '../layouts/BaseLayout.astro';

const query = Astro.url.searchParams.get('q') || '';
---

<BaseLayout title={`Search${query ? ` - ${query}` : ''} | George Ollis`} description="Search blog posts and guides.">
  <section class="section-block search-results">
    <p class="section-label">Search</p>
    <h1>Search Results</h1>

    {query ? (
      <div id="pagefind-ui" data-ui="light"></div>
    ) : (
      <div class="search-info">
        <p>Enter a search query to find posts.</p>
      </div>
    )}
  </section>
</BaseLayout>

<style>
  .search-results {
    max-width: 900px;
  }

  .search-info {
    padding: 1.5rem;
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: 0.5rem;
    margin: 2rem 0;
  }

  .search-info p {
    margin: 0.75rem 0;
    color: var(--muted);
  }

  .search-info p:first-child {
    margin-top: 0;
  }


  .search-info p:last-child {
    margin-bottom: 0;
  }

  .search-info strong {
    color: var(--accent);
  }
</style>

<script define:vars={{ query }}>
  if (query && window.PagefindUI) {
    new window.PagefindUI({
      element: '#pagefind-ui',
      showSubResults: true,
      autofocus: false
    });
  }
</script>
