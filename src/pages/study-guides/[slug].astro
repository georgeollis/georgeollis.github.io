---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const certifications = await getCollection('certifications', ({ data }) => !data.draft);
  return certifications.map((certification) => ({
    params: { slug: certification.slug },
    props: { certification }
  }));
}

const { certification } = Astro.props;
const { Content } = await render(certification);
---

<BaseLayout title={`${certification.data.title} | George Ollis`} description={certification.data.description}>
  <article class="article-shell">
    <header class="article-header">
      <p class="section-label">{certification.data.provider}</p>
      <h1>{certification.data.title}</h1>
      <p class="lede">{certification.data.description}</p>
      <div class="detail-meta">
        {certification.data.examCode && <span>Exam: {certification.data.examCode}</span>}
        <span>Status: {certification.data.status}</span>
      </div>
    </header>
    <div class="prose">
      <Content />
    </div>
  </article>
</BaseLayout>
