---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const certifications = (await getCollection('certifications', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
---

<BaseLayout title="Certifications | George Ollis" description="Certification notes and study plans.">
  <section class="section-block">
    <p class="section-label">Certifications</p>
    <h1>Certification notes</h1>
    <p class="lede">Planned exams, study notes, and mock entries ready to be replaced with real content.</p>

    <div class="card-grid card-grid-compact">
      {certifications.map((certification) => (
        <article class="card">
          <a class="card-link" href={`/certifications/${certification.slug}/`}>
            <p class="card-meta">{certification.data.provider}</p>
            <h2>{certification.data.title}</h2>
            <p>{certification.data.description}</p>
          </a>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
