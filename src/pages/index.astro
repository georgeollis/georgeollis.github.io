---
import BaseLayout from '../layouts/BaseLayout.astro';

const schema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Person",
  "name": "George Ollis",
  "url": "https://www.georgeollis.com",
  "sameAs": [
    "https://www.linkedin.com/in/georgeollis/",
    "https://github.com/georgeollis"
  ],
  "jobTitle": "Cloud Architect",
  "description": "Cloud Architect and Kubestronaut with over 40 Microsoft certifications, specialising in Azure apps, AI, and Microsoft Foundry."
});
---

<BaseLayout
  title="George Ollis — Cloud Architect & Kubestronaut"
  description="Cloud Architect and Kubestronaut with over 40 Microsoft certifications, specialising in Azure apps, AI, and Microsoft Foundry."
>
  <script type="application/ld+json" set:html={schema} />
  <section class="home-hero">
    <h1 class="home-name">George Ollis</h1>
    <p class="home-bio">
      Cloud Architect and Kubestronaut with over 40 Microsoft certifications, specialising in Azure -
      particularly apps, AI, and Microsoft Foundry. I write about what I build and learn.
    </p>
    <div class="home-links">
      <a class="home-link" href="/blog">Blog</a>
      <a class="home-link" href="/certifications">Certifications</a>
      <a class="home-link home-link-external" href="https://www.linkedin.com/in/georgeollis/" target="_blank" rel="noopener noreferrer">LinkedIn</a>
      <a class="home-link home-link-external" href="https://github.com/georgeollis" target="_blank" rel="noopener noreferrer">GitHub</a>
    </div>

    <div class="topic-pills" aria-label="Featured topics">
      <a href="/blog?topic=azure-apps">Azure Apps</a>
      <a href="/blog?topic=ai">AI</a>
      <a href="/blog?topic=microsoft-foundry">Microsoft Foundry</a>
      <a href="/blog?topic=kubernetes">Kubernetes</a>
    </div>
  </section>
</BaseLayout>
