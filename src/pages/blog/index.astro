---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const tagCounts = new Map<string, number>();
const yearCounts = new Map<string, number>();

for (const post of posts) {
  const year = post.data.date.getFullYear().toString();
  yearCounts.set(year, (yearCounts.get(year) ?? 0) + 1);

  for (const tag of post.data.tags ?? []) {
    tagCounts.set(tag, (tagCounts.get(tag) ?? 0) + 1);
  }
}

const tags = [...tagCounts.entries()].sort((a, b) => {
  if (b[1] !== a[1]) return b[1] - a[1];
  return a[0].localeCompare(b[0]);
});

const years = [...yearCounts.entries()].sort((a, b) => Number(b[0]) - Number(a[0]));

const visibleTags = tags.slice(0, 5);
const hiddenTags = tags.slice(5);

// Function to strip HTML tags and decode entities
function stripHtml(html: string): string {
  if (!html) return '';
  return html
    .replace(/<[^>]*>/g, '') // Remove HTML tags
    .replace(/&lt;/g, '<')
    .replace(/&gt;/g, '>')
    .replace(/&quot;/g, '"')
    .replace(/&#039;/g, "'")
    .replace(/&amp;/g, '&')
    .replace(/\s+/g, ' ')
    .trim();
}
---

<BaseLayout title="Blog | George Ollis" description="All blog posts by George Ollis.">
  <section class="section-block blog-archive">
    <p class="section-label">Blog</p>

    <div class="archive-results-bar">
      <p data-results-count aria-live="polite">{posts.length} posts</p>
      <div class="archive-active-filters" data-active-filters hidden></div>
    </div>

    <div class="archive-layout">
      <aside class="archive-filters" aria-label="Blog filters">
        <div class="filter-card">
          <div class="filter-card-header">
            <h2>Filters</h2>
            <button class="filter-clear" type="button" data-clear-filters hidden>Clear</button>
          </div>

          <div class="filter-group">
            <h3>Year</h3>
            <div class="filter-list">
              {years.map(([year, count]) => (
                <button
                  class="filter-pill"
                  type="button"
                  aria-pressed="false"
                  data-filter-type="year"
                  data-filter-value={year}
                >
                  <span>{year}</span>
                  <span>{count}</span>
                </button>
              ))}
            </div>
          </div>

          <div class="filter-group">
            <h3>Tags</h3>
            <div class="filter-list">
              {visibleTags.map(([tag, count]) => (
                <button
                  class="filter-pill"
                  type="button"
                  aria-pressed="false"
                  data-filter-type="tag"
                  data-filter-value={tag}
                >
                  <span>{tag}</span>
                  <span>{count}</span>
                </button>
              ))}
            </div>

            {hiddenTags.length > 0 && (
              <>
                <div class="filter-list filter-list-extra" data-expanded="false" id="tag-filter-extra" hidden>
                  {hiddenTags.map(([tag, count]) => (
                    <button
                      class="filter-pill"
                      type="button"
                      aria-pressed="false"
                      data-filter-type="tag"
                      data-filter-value={tag}
                    >
                      <span>{tag}</span>
                      <span>{count}</span>
                    </button>
                  ))}
                </div>

                <button
                  class="filter-expand"
                  type="button"
                  aria-expanded="false"
                  aria-controls="tag-filter-extra"
                  data-expand-tags
                >
                  Show more tags
                </button>
              </>
            )}
          </div>
        </div>
      </aside>

      <div class="archive-posts">
        <div class="blog-grid" id="blog-grid">
          {posts.map((post) => (
            <a
              class="blog-card"
              href={`/blog/${post.slug}/`}
              data-tags={(post.data.tags ?? []).map((tag) => tag.toLowerCase()).join('|')}
              data-year={post.data.date.getFullYear().toString()}
            >
              <div class="card-header">
                <h3 class="card-title">{post.data.title}</h3>
                <span class="card-date">{post.data.date.toLocaleDateString('en-US', {
                  year: 'numeric',
                  month: 'short',
                  day: 'numeric'
                })}</span>
              </div>
              {post.data.description && (
                <p class="card-description">{stripHtml(post.data.description).substring(0, 180)}...</p>
              )}
              {post.data.tags && post.data.tags.length > 0 && (
                <div class="card-tags">
                  {post.data.tags.slice(0, 3).map((tag) => (
                    <span class="tag">{tag}</span>
                  ))}
                </div>
              )}
            </a>
          ))}
        </div>

        <div class="archive-empty-state" data-empty-state hidden>
          <p>No posts match the current filters.</p>
          <a href="/blog">View all posts</a>
        </div>
      </div>
    </div>
  </section>

  <style>
    .archive-layout {
      display: grid;
      grid-template-columns: 17rem minmax(0, 1fr);
      gap: 2rem;
      align-items: start;
    }

    .archive-filters {
      position: sticky;
      top: 6rem;
    }

    .filter-card {
      border: 1px solid var(--line);
      border-radius: 0.8rem;
      padding: 1.1rem;
      background: #000000;
      max-height: calc(100vh - 8rem);
      overflow-y: auto;
      scrollbar-width: thin;
      scrollbar-color: color-mix(in srgb, var(--accent-strong) 40%, transparent) transparent;
      scrollbar-gutter: stable;
    }

    :root[data-theme="dark"] .filter-card {
      background: #000000;
      border-color: rgba(255, 255, 255, 0.12);
    }

    :root[data-theme="modern"] .filter-card {
      background: var(--surface);
      border-color: var(--line);
    }

    .archive-posts {
      min-width: 0;
    }

    .filter-card::-webkit-scrollbar {
      width: 0.45rem;
    }

    .filter-card::-webkit-scrollbar-thumb {
      background: color-mix(in srgb, var(--accent-strong) 44%, transparent);
      border-radius: 999px;
      min-height: 2.5rem;
    }

    .filter-card::-webkit-scrollbar-track {
      background: transparent;
      border-radius: 999px;
      margin-block: 0.2rem;
    }

    .filter-card::-webkit-scrollbar-thumb:hover {
      background: color-mix(in srgb, var(--accent-strong) 68%, transparent);
    }

    .filter-card::-webkit-scrollbar-corner {
      background: transparent;
    }

    .filter-card-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1rem;
      margin-bottom: 1rem;
    }

    .filter-card-header h2,
    .filter-group h3 {
      margin: 0;
      font-family: 'Space Mono', monospace;
      font-size: 0.9rem;
      letter-spacing: 0.04em;
      text-transform: uppercase;
      color: #ffffff;
    }

    .filter-clear {
      appearance: none;
      border: 0;
      padding: 0;
      background: transparent;
      cursor: pointer;
      color: var(--accent-strong);
      text-decoration: none;
      font-family: 'Space Mono', monospace;
      font-size: 0.9rem;
    }

    .filter-group + .filter-group {
      margin-top: 1.5rem;
    }

    .filter-list {
      display: flex;
      flex-wrap: wrap;
      gap: 0.6rem;
      margin-top: 0.85rem;
    }

    .filter-pill {
      appearance: none;
      display: inline-flex;
      align-items: center;
      justify-content: space-between;
      gap: 0.65rem;
      min-width: max-content;
      padding: 0.45rem 0.7rem;
      border: 1px solid rgba(255, 255, 255, 0.14);
      border-radius: 999px;
      color: #ffffff;
      text-decoration: none;
      background: rgba(255, 255, 255, 0.03);
      font-family: 'Space Mono', monospace;
      font-size: 0.78rem;
      cursor: pointer;
      transition: border-color 0.15s ease, transform 0.15s ease, background 0.15s ease;
    }

    .filter-pill:hover {
      transform: translateY(-1px);
      border-color: var(--accent-strong);
      background: rgba(255, 255, 255, 0.08);
    }

    .filter-pill.is-active {
      background: var(--accent-strong);
      border-color: var(--accent-strong);
      color: #ffffff;
    }

    .filter-expand {
      appearance: none;
      margin-top: 0.9rem;
      padding: 0;
      border: 0;
      background: transparent;
      color: var(--accent-strong);
      font-family: 'Space Mono', monospace;
      font-size: 0.75rem;
      cursor: pointer;
    }

    .filter-list-extra {
      margin-top: 0.6rem;
    }

    .filter-list-extra[hidden] {
      display: none;
    }

    .archive-results-bar {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1rem;
      margin-bottom: 1.25rem;
    }

    .archive-results-bar p {
      margin: 0;
      color: var(--muted);
      font-family: 'Space Mono', monospace;
      font-size: 0.85rem;
    }

    .archive-active-filters {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
      font-family: 'Space Mono', monospace;
    }

    .active-filter-chip {
      padding: 0.35rem 0.65rem;
      border-radius: 999px;
      background: color-mix(in srgb, var(--accent-strong) 16%, transparent);
      color: var(--accent-strong);
      font-family: 'Space Mono', monospace;
      font-size: 0.75rem;
      letter-spacing: 0.02em;
    }

    .archive-empty-state {
      margin-top: 1.5rem;
      padding: 1.25rem;
      border: 1px solid var(--line);
      border-radius: 0.8rem;
      background: var(--surface);
    }

    .archive-empty-state p {
      margin: 0 0 0.75rem;
    }

    .archive-empty-state a {
      color: var(--accent-strong);
      text-decoration: none;
    }

    .blog-card[data-hidden] {
      display: none;
    }

    @media (max-width: 900px) {
      .archive-layout {
        grid-template-columns: 1fr;
      }

      .archive-filters {
        position: static;
      }

      .filter-card {
        max-height: none;
        overflow-y: visible;
      }

      .archive-results-bar {
        flex-direction: column;
        align-items: flex-start;
      }
    }
  </style>

  <script is:inline>
    (() => {
      const cards = Array.from(document.querySelectorAll('.blog-card'));
      const filterButtons = Array.from(document.querySelectorAll('[data-filter-type]'));
      const clearButton = document.querySelector('[data-clear-filters]');
      const resultsCount = document.querySelector('[data-results-count]');
      const activeFilters = document.querySelector('[data-active-filters]');
      const emptyState = document.querySelector('[data-empty-state]');
      const expandTagsButton = document.querySelector('[data-expand-tags]');
      const extraTagList = document.getElementById('tag-filter-extra');

      const params = new URLSearchParams(window.location.search);
      const state = {
        tag: params.get('tag'),
        year: params.get('year')
      };

      const renderActiveFilters = () => {
        if (!activeFilters) return;

        const chips = [];
        if (state.tag) chips.push(`<span class="active-filter-chip">Tag: ${state.tag}</span>`);
        if (state.year) chips.push(`<span class="active-filter-chip">Year: ${state.year}</span>`);

        activeFilters.innerHTML = chips.join('');
        activeFilters.hidden = chips.length === 0;
      };

      const updateUrl = () => {
        const next = new URLSearchParams();
        if (state.tag) next.set('tag', state.tag);
        if (state.year) next.set('year', state.year);
        const query = next.toString();
        const nextUrl = query ? `${window.location.pathname}?${query}` : window.location.pathname;
        window.history.replaceState({}, '', nextUrl);
      };

      const applyFilters = () => {
        let visibleCount = 0;

        for (const card of cards) {
          const cardTags = (card.getAttribute('data-tags') || '').split('|').filter(Boolean);
          const cardYear = card.getAttribute('data-year');

          const matchesTag = !state.tag || cardTags.includes(state.tag.toLowerCase());
          const matchesYear = !state.year || cardYear === state.year;
          const visible = matchesTag && matchesYear;

          card.toggleAttribute('data-hidden', !visible);
          if (visible) visibleCount += 1;
        }

        for (const button of filterButtons) {
          const type = button.getAttribute('data-filter-type');
          const value = button.getAttribute('data-filter-value');
          const active = (type === 'tag' && state.tag === value) || (type === 'year' && state.year === value);
          button.classList.toggle('is-active', active);
          button.setAttribute('aria-pressed', String(active));
        }

        if (resultsCount) {
          resultsCount.textContent = `${visibleCount} post${visibleCount === 1 ? '' : 's'}`;
        }

        if (clearButton) {
          clearButton.hidden = !(state.tag || state.year);
        }

        if (emptyState) {
          emptyState.hidden = visibleCount !== 0;
        }

        renderActiveFilters();
        updateUrl();
      };

      for (const button of filterButtons) {
        button.addEventListener('click', () => {
          const type = button.getAttribute('data-filter-type');
          const value = button.getAttribute('data-filter-value');
          if (!type || !value) return;

          state[type] = state[type] === value ? null : value;
          applyFilters();
        });
      }

      clearButton?.addEventListener('click', () => {
        state.tag = null;
        state.year = null;
        applyFilters();
      });

      expandTagsButton?.addEventListener('click', () => {
        if (!extraTagList) return;

        const expanded = extraTagList.getAttribute('data-expanded') === 'true';
        extraTagList.hidden = expanded;
        extraTagList.setAttribute('data-expanded', String(!expanded));
        expandTagsButton.setAttribute('aria-expanded', String(!expanded));
        expandTagsButton.textContent = expanded ? 'Show more tags' : 'Show fewer tags';
      });

      applyFilters();
    })();
  </script>
</BaseLayout>
