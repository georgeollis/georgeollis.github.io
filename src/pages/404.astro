---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Page not found | George Ollis" description="The page you requested was not found.">
  <section class="section-block not-found">
    <p class="section-label">404</p>
    <h1>Page not found</h1>
    <p class="lede">The page may have moved, been deleted, or the URL might be incorrect.</p>
    <div class="home-links">
      <a class="home-link" href="/">Home</a>
      <a class="home-link" href="/blog">Blog</a>
    </div>
  </section>
</BaseLayout>
