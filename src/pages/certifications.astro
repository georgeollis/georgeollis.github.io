---
import BaseLayout from '../layouts/BaseLayout.astro';
import certifications from '../data/certifications.json';

const today = new Date('2026-05-06');

// Filter to only active certifications (not expired)
const activeCerts = certifications.filter((c) => {
  if (!c.expires) return true; // No expiry = always active
  return new Date(c.expires) > today;
}).sort((a, b) => new Date(b.issued).getTime() - new Date(a.issued).getTime());

// Organize by year for timeline
const certsByYear = new Map();
activeCerts.forEach((cert) => {
  const year = new Date(cert.issued).getFullYear();
  if (!certsByYear.has(year)) {
    certsByYear.set(year, []);
  }
  certsByYear.get(year).push(cert);
});

const years = Array.from(certsByYear.keys()).sort();

// Count by organization
const orgCount = activeCerts.reduce((acc, cert) => {
  acc[cert.organization] = (acc[cert.organization] || 0) + 1;
  return acc;
}, {});

// Count by category
const categoryCount = activeCerts.reduce((acc, cert) => {
  acc[cert.category] = (acc[cert.category] || 0) + 1;
  return acc;
}, {});

const totalCerts = activeCerts.length;
---

<BaseLayout title="My Certifications | George Ollis" description="Interactive timeline of earned certifications and credentials.">
  <section class="section-block">
    <p class="section-label">Credentials</p>
    <h1>My Certifications</h1>

    <!-- Timeline Graph -->
    <div class="timeline-graph-section">
      <div class="timeline-graph">
        {years.map((year) => {
          const yearCerts = certsByYear.get(year);
          const maxInYear = Math.max(...Array.from(certsByYear.values()).map((v) => v.length));
          const height = (yearCerts.length / maxInYear) * 100;
          return (
            <div class="timeline-bar-container">
              <div class="timeline-bar" style={`height: ${height}%`}>
                <span class="bar-label">{yearCerts.length}</span>
              </div>
              <span class="bar-year">{year}</span>
            </div>
          );
        })}
      </div>
    </div>

    <!-- Certifications List -->
    <div class="certs-list-section">
      <h2>All Certifications</h2>
      <div class="certs-list">
        {activeCerts.map((cert) => {
          const expiryDate = cert.expires ? new Date(cert.expires) : null;
          const monthsUntilExpiry = expiryDate 
            ? Math.ceil((expiryDate.getTime() - today.getTime()) / (1000 * 60 * 60 * 24 * 30))
            : null;
          
          return (
            <div class="cert-list-item">
              <div class="cert-list-header">
                <h3>{cert.name}</h3>
                {cert.credentialId && <span class="credential-id">{cert.credentialId}</span>}
              </div>
              <div class="cert-list-meta">
                <span class="org-badge">{cert.organization}</span>
                <span class="category-badge">{cert.category}</span>
                <span class="date">
                  {new Date(cert.issued).toLocaleDateString('en-GB', { month: 'short', year: 'numeric' })}
                </span>
              </div>
            </div>
          );
        })}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .stats-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1.5rem;
    margin: 3rem 0;
  }

  .stat-card {
    padding: 1.5rem;
    border: 1px solid var(--line);
    border-radius: 0.5rem;
    background: var(--surface);
    text-align: center;
  }

  .stat-number {
    font-size: 2.5rem;
    font-weight: 700;
    color: var(--accent);
    line-height: 1;
  }

  .stat-label {
    font-size: 0.9rem;
    color: var(--muted);
    margin-top: 0.5rem;
  }

  .timeline-graph-section {
    margin: 3rem 0;
  }

  .timeline-graph {
    display: flex;
    align-items: flex-end;
    gap: 0.75rem;
    height: 200px;
    margin: 2rem 0;
    padding: 1.5rem;
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: 0.5rem;
  }

  .timeline-bar-container {
    display: flex;
    flex-direction: column;
    align-items: center;
    flex: 1;
    height: 100%;
    gap: 0.5rem;
  }

  .timeline-bar {
    width: 100%;
    background: linear-gradient(to top, var(--accent), color-mix(in srgb, var(--accent) 60%, transparent));
    border-radius: 0.25rem 0.25rem 0 0;
    min-height: 20px;
    position: relative;
    transition: all 200ms ease;
  }

  .timeline-bar:hover {
    filter: brightness(1.1);
  }

  .bar-label {
    position: absolute;
    bottom: -1.5rem;
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--muted);
  }

  .bar-year {
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--ink);
    margin-top: 1.5rem;
  }

  .certs-list-section {
    margin-top: 3rem;
  }

  .certs-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-top: 2rem;
  }

  .cert-list-item {
    padding: 1rem;
    border: 1px solid var(--line);
    border-radius: 0.5rem;
    background: color-mix(in srgb, var(--bg) 70%, var(--surface));
    transition: all 200ms ease;
  }

  .cert-list-item:hover {
    border-color: var(--accent);
    background: var(--surface);
  }

  .cert-list-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 1rem;
    margin-bottom: 0.75rem;
  }

  .cert-list-header h3 {
    margin: 0;
    font-size: 1rem;
    color: var(--ink);
  }

  .credential-id {
    font-size: 0.75rem;
    color: var(--muted);
    font-family: monospace;
    white-space: nowrap;
  }

  .cert-list-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    font-size: 0.85rem;
  }

  .org-badge,
  .category-badge {
    display: inline-block;
    padding: 0.25rem 0.6rem;
    background: color-mix(in srgb, var(--accent) 15%, transparent);
    border: 1px solid color-mix(in srgb, var(--accent) 30%, transparent);
    border-radius: 0.25rem;
    color: var(--accent);
    font-weight: 500;
    text-transform: lowercase;
    letter-spacing: 0.02em;
  }

  .date {
    color: var(--muted);
    font-weight: 500;
  }

  @media (max-width: 760px) {
    .stats-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 1rem;
    }

    .timeline-graph {
      gap: 0.5rem;
    }

    .category-item {
      flex-direction: column;
      align-items: flex-start;
    }

    .category-label {
      width: auto;
    }
  }
</style>
